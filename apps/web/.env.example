DATABASE_URL=postgresql://user:password@host/database
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001
GITHUB_CLIENT_ID=replace-with-your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=replace-with-your-github-oauth-app-client-secret
POLAR_ACCESS_TOKEN=replace-with-your-polar-sandbox-access-token
POLAR_PREMIUM_ACCESS_PRODUCT_ID=replace-with-your-annual-product-id
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=http://localhost:3001/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=replace-with-your-polar-webhook-secret
# Required together with POLAR_SERVER=production before production checkout is enabled.
# POLAR_LEGAL_REVIEW_REFERENCE=legal-review-record-or-url
# Server-only JSON registry item for the immutable protected Command Pack Release.
# COMMAND_PREMIUM_RELEASE={"...":"provision from private storage"}
# Server-only JSON registry item and pinned digest for the immutable protected Signal Pack Release.
# SIGNAL_PREMIUM_RELEASE={"...":"provision from private storage"}
# SIGNAL_PREMIUM_RELEASE_SHA256=replace-with-release-sha256
