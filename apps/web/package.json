{
	"name": "web",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --port 3001",
		"dev:test": "next dev --port 3011",
		"build": "bun run registry:build && next build && bun run artifacts:verify",
		"database:test:prepare": "bun run --cwd ../../packages/db db:prepare:black-box",
		"check-types": "tsc --noEmit",
		"registry:build": "bun run scripts/build-registry.ts",
		"artifacts:verify": "bun run scripts/verify-premium-artifacts.ts",
		"logs:verify": "bun run scripts/verify-premium-logs.ts",
		"test": "bun run --cwd ../../packages/design-packs build && AGENTKOGEI_CLI_PATH=../../packages/design-packs/dist/agentkogei.js playwright test && bun run logs:verify",
		"test:public": "bun run --cwd ../../packages/design-packs build && AGENTKOGEI_CLI_PATH=../../packages/design-packs/dist/agentkogei.js playwright test tests/public-journey.spec.ts",
		"start": "next start",
		"start:test": "next start --port 3011"
	},
	"dependencies": {
		"@agentkogei/api": "workspace:*",
		"@agentkogei/auth": "workspace:*",
		"@agentkogei/design-packs": "workspace:*",
		"@agentkogei/env": "workspace:*",
		"@agentkogei/ui": "workspace:*",
		"@orpc/client": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/tanstack-query": "^1.14.6",
		"@orpc/zod": "catalog:",
		"@polar-sh/better-auth": "catalog:",
		"@swc/helpers": "^0.5.23",
		"@tanstack/react-query": "^5.101.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"lucide-react": "catalog:",
		"next": "catalog:",
		"next-themes": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"sonner": "catalog:"
	},
	"devDependencies": {
		"@agentkogei/config": "workspace:*",
		"@axe-core/playwright": "^4.12.1",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "catalog:",
		"@tanstack/react-query-devtools": "^5.101.2",
		"@types/node": "^20",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:"
	}
