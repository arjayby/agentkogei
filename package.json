{
  "name": "agentkogei",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "lucide-react": "^1.23.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@orpc/server": "^1.14.6",
      "@orpc/client": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "better-auth": "1.6.23",
      "@polar-sh/better-auth": "^1.8.4",
      "@tailwindcss/postcss": "^4.3.2",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "bun run --cwd apps/web test",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @agentkogei/db",
    "db:studio": "turbo run db:studio -F @agentkogei/db",
    "db:generate": "turbo run db:generate -F @agentkogei/db",
    "db:migrate": "turbo run db:migrate -F @agentkogei/db",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@agentkogei/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@agentkogei/config": "workspace:*",
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^22.13.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "vercel": "^54.18.6"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  },
  "packageManager": "bun@1.3.13"
}
