{
	"name": "@agentkogei/design-packs",
	"version": "0.1.0",
	"license": "MIT",
	"type": "module",
	"bin": {
		"agentkogei": "./dist/agentkogei.js",
		"agentkogei-validate-pack": "./dist/agentkogei-validate-pack.js"
	},
	"files": [
		"dist",
		"LICENSE"
	],
	"exports": {
		".": "./src/index.ts",
		"./design-contract": "./src/design-contract.ts",
		"./diagnostic-contract": "./src/diagnostic-contract.ts",
		"./release-version": "./src/release-version.ts"
	},
	"scripts": {
		"build": "bun build ./src/install-cli.ts --target=bun --outfile=./dist/agentkogei.js && bun build ./src/cli.ts --target=bun --outfile=./dist/agentkogei-validate-pack.js",
		"check-types": "tsc --noEmit",
		"distribution:verify": "bun run build && bun run scripts/verify-packed-cli.ts",
		"test": "bun test --timeout 30000",
		"validate": "bun run src/cli.ts"
	},
	"dependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"@agentkogei/config": "workspace:*",
		"typescript": "catalog:"
	}
}
