# Local env files must never ship in deployments: Vercel project env vars are
# the source of truth (bun env:vercel:*), and frameworks like Next.js would
# otherwise load these localhost values at runtime.
.env
.env.*
**/.env
**/.env.*
!**/.env.example
node_modules/
**/node_modules/
.next/
**/.next/
.next-test/
**/.next-test/
.turbo/
**/.turbo/
test-results/
**/test-results/
playwright-report/
**/playwright-report/
local.db
local.db-*
.alchemy/
